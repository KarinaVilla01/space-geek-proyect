---
export const prerender = false

import { createSupabaseClient } from '../../lib/supabase'
import '../../styles/global.css'

const supabase = createSupabaseClient()

const accessToken = Astro.cookies.get('sb-access-token')
const refreshToken = Astro.cookies.get('sb-refresh-token')

if (!accessToken || !refreshToken) {
  return Astro.redirect('/admin/login')
}

let sessionResult

try {
  sessionResult = await supabase.auth.setSession({
    access_token: accessToken.value,
    refresh_token: refreshToken.value,
  })

  if (sessionResult.error || !sessionResult.data.user) {
    Astro.cookies.delete('sb-access-token', { path: '/' })
    Astro.cookies.delete('sb-refresh-token', { path: '/' })
    return Astro.redirect('/admin/login')
  }
} catch {
  Astro.cookies.delete('sb-access-token', { path: '/' })
  Astro.cookies.delete('sb-refresh-token', { path: '/' })
  return Astro.redirect('/admin/login')
}

const user = sessionResult.data.user

const { data: adminUser } = await supabase
  .from('admin_users')
  .select('id, role, is_active')
  .eq('id', user.id)
  .maybeSingle()

if (!adminUser || adminUser.role !== 'admin' || adminUser.is_active !== true) {
  Astro.cookies.delete('sb-access-token', { path: '/' })
  Astro.cookies.delete('sb-refresh-token', { path: '/' })
  return Astro.redirect('/admin/login?error=Not%20authorized')
}
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin</title>
  </head>
  <body>
    <main>
      <div class="dashboard">
        <section class="hero">
          <div class="hero__header">
            <div class="hero__text">
              <p class="eyebrow">Panel administrativo</p>
              <h1>Bienvenida, {user.email}</h1>
              <p>Gestiona tus publicaciones, crea contenido nuevo y controla tu admin desde un panel limpio, rápido y enfocado.</p>
            </div>
            <div class="actions">
              <form action="/api/auth/logout" method="get">
                <button type="submit" class="logout-button">Cerrar sesión</button>
              </form>
            </div>
          </div>
        </section>

        <section class="cards">
          <article class="card">
            <h2>Ver publicaciones</h2>
            <p>Accede al listado de posts, revisa el estado y edita cada entrada rápidamente.</p>
            <a href="/admin/posts">Ir a publicaciones</a>
          </article>

          <article class="card">
            <h2>Nueva publicación</h2>
            <p>Crea un nuevo artículo, sube imagen destacada y publica el contenido en tu sitio.</p>
            <a href="/admin/posts/new">Crear publicación</a>
          </article>
        </section>

      </div>
    </main>
  </body>
</html>