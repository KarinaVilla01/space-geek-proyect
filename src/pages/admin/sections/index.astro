---
export const prerender = false;

import { createSupabaseClient } from "../../../lib/supabase";
import "../../../styles/global.css";

const supabase = createSupabaseClient();

const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
  return Astro.redirect("/admin/loginOscarUnique");
}

let sessionResult;
try {
  sessionResult = await supabase.auth.setSession({
    access_token: accessToken.value,
    refresh_token: refreshToken.value,
  });
  if (sessionResult.error || !sessionResult.data.user) {
    Astro.cookies.delete("sb-access-token", { path: "/" });
    Astro.cookies.delete("sb-refresh-token", { path: "/" });
    return Astro.redirect("/admin/loginOscarUnique");
  }
} catch {
  Astro.cookies.delete("sb-access-token", { path: "/" });
  Astro.cookies.delete("sb-refresh-token", { path: "/" });
  return Astro.redirect("/admin/loginOscarUnique");
}

const { data: adminUser } = await supabase
  .from("admin_users")
  .select("id, role, is_active")
  .eq("id", sessionResult.data.user.id)
  .maybeSingle();

if (!adminUser || adminUser.role !== "admin" || adminUser.is_active !== true) {
  return Astro.redirect("/admin/loginOscarUnique?error=Not%20authorized");
}

const { data: sections } = await supabase
  .from("post_sections")
  .select("id, slug, label, sort_order")
  .order("sort_order", { ascending: true });

// Count posts per section for display
const { data: postCounts } = await supabase
  .from("posts")
  .select("post_type");

const countMap: Record<string, number> = {};
for (const p of postCounts ?? []) {
  countMap[p.post_type] = (countMap[p.post_type] ?? 0) + 1;
}

const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Secciones</title>
    <link rel="icon" type="image/x-icon" href="/Logo.png" />
  </head>
  <body>
    <main>
      <div class="dashboard">
        <section class="hero">
          <div class="hero__header">
            <div class="hero__text">
              <p class="eyebrow">Panel administrativo</p>
              <h1>Secciones</h1>
              <p>Crea y elimina las secciones que aparecen al crear publicaciones.</p>
            </div>
            <div class="actions actions--row">
              <a class="secondary-button" href="/admin">Volver al panel</a>
            </div>
          </div>
        </section>

        <section class="content-card">
          {error && (
            <div class="notification notification--error">
              <strong>Error:</strong> {error}
            </div>
          )}
          {success && (
            <div class="notification notification--success">
              <strong>{success}</strong>
            </div>
          )}

          <h2 style="margin-bottom: 1rem;">Nueva sección</h2>
          <form
            method="POST"
            action="/api/admin/sections/create"
            class="post-form"
            id="section-form"
          >
            <div class="form-grid">
              <div class="form-group">
                <label for="label">Nombre visible</label>
                <input
                  id="label"
                  name="label"
                  type="text"
                  required
                  placeholder="Ej: Cultura Otaku"
                  class="form-input"
                />
              </div>
              <div class="form-group">
                <label for="slug">Slug (identificador)</label>
                <input
                  id="slug"
                  name="slug"
                  type="text"
                  required
                  placeholder="Ej: cultura-otaku"
                  class="form-input"
                />
              </div>
            </div>
            <div class="form-actions" style="margin-top: 1rem;">
              <button type="submit" class="secondary-button">Agregar sección</button>
            </div>
          </form>

          <hr style="margin: 2rem 0; border-color: rgba(255,255,255,0.1);" />

          <h2 style="margin-bottom: 1rem;">Secciones existentes</h2>

          {sections && sections.length > 0 ? (
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Slug</th>
                  <th>Posts</th>
                  <th>Acción</th>
                </tr>
              </thead>
              <tbody>
                {sections.map((section) => (
                  <tr>
                    <td>{section.label}</td>
                    <td>
                      <code style="background:rgba(255,255,255,0.08);padding:2px 6px;border-radius:4px;">
                        {section.slug}
                      </code>
                    </td>
                    <td>{countMap[section.slug] ?? 0}</td>
                    <td>
                      {(countMap[section.slug] ?? 0) === 0 ? (
                        <form method="POST" action="/api/admin/sections/delete" style="display:inline">
                          <input type="hidden" name="id" value={section.id} />
                          <button
                            type="submit"
                            class="delete-button"
                            onclick="return confirm('¿Eliminar la sección «' + this.closest('tr').querySelector('td').textContent + '»?')"
                          >
                            Eliminar
                          </button>
                        </form>
                      ) : (
                        <span style="opacity:0.4;font-size:0.85rem;">En uso</span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          ) : (
            <p style="opacity: 0.6;">No hay secciones aún.</p>
          )}
        </section>
      </div>
    </main>

    <script>
      const labelInput = document.getElementById("label") as HTMLInputElement;
      const slugInput = document.getElementById("slug") as HTMLInputElement;
      let userEditedSlug = false;

      function toSlug(text: string) {
        return text
          .toLowerCase()
          .normalize("NFD")
          .replace(/[̀-ͯ]/g, "")
          .replace(/[^a-z0-9\s-]/g, "")
          .trim()
          .replace(/\s+/g, "-")
          .replace(/-+/g, "-");
      }

      labelInput?.addEventListener("input", () => {
        if (!userEditedSlug) {
          slugInput.value = toSlug(labelInput.value);
        }
      });

      slugInput?.addEventListener("input", () => {
        userEditedSlug = true;
      });
    </script>

    <style>
      .admin-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
      }
      .admin-table th,
      .admin-table td {
        text-align: left;
        padding: 0.65rem 0.75rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      .admin-table th {
        opacity: 0.6;
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .delete-button {
        background: transparent;
        border: 1px solid rgba(220, 38, 38, 0.5);
        color: #f87171;
        padding: 0.25rem 0.65rem;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.85rem;
        transition: background 0.15s;
      }
      .delete-button:hover {
        background: rgba(220, 38, 38, 0.15);
      }
    </style>
  </body>
</html>
