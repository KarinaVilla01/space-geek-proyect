---
export const prerender = false

import { createSupabaseClient } from '../../../lib/supabase'
import { ensureUniqueSlugBase } from '../../../lib/utils/slug'

const supabase = createSupabaseClient()

const accessToken = Astro.cookies.get('sb-access-token')
const refreshToken = Astro.cookies.get('sb-refresh-token')

if (!accessToken || !refreshToken) {
  return Astro.redirect('/admin/login')
}

let sessionResult

try {
  sessionResult = await supabase.auth.setSession({
    access_token: accessToken.value,
    refresh_token: refreshToken.value,
  })

  if (sessionResult.error || !sessionResult.data.user) {
    Astro.cookies.delete('sb-access-token', { path: '/' })
    Astro.cookies.delete('sb-refresh-token', { path: '/' })
    return Astro.redirect('/admin/login')
  }
} catch {
  Astro.cookies.delete('sb-access-token', { path: '/' })
  Astro.cookies.delete('sb-refresh-token', { path: '/' })
  return Astro.redirect('/admin/login')
}

const user = sessionResult.data.user

const { data: adminUser } = await supabase
  .from('admin_users')
  .select('id, role, is_active')
  .eq('id', user.id)
  .maybeSingle()

if (!adminUser || adminUser.role !== 'admin' || adminUser.is_active !== true) {
  Astro.cookies.delete('sb-access-token', { path: '/' })
  Astro.cookies.delete('sb-refresh-token', { path: '/' })
  return Astro.redirect('/admin/login?error=Not%20authorized')
}

const error = Astro.url.searchParams.get('error')
const success = Astro.url.searchParams.get('success')
const title = Astro.url.searchParams.get('title') ?? ''
const slug = Astro.url.searchParams.get('slug') ?? ''
const excerpt = Astro.url.searchParams.get('excerpt') ?? ''
const content_md = Astro.url.searchParams.get('content_md') ?? ''
const post_type = Astro.url.searchParams.get('post_type') ?? 'blog'
const status = Astro.url.searchParams.get('status') ?? 'draft'

const suggestedSlug = title ? ensureUniqueSlugBase(title) : ''
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nueva publicación</title>
  </head>
  <body>
    <main>
      <h1>Nueva publicación</h1>

      <nav>
        <a href="/admin">Volver al panel</a>
        {' | '}
        <a href="/admin/posts">Ver publicaciones</a>
      </nav>

      {error && <p><strong>Error:</strong> {error}</p>}
      {success && <p><strong>{success}</strong></p>}

      <form method="POST" action="/api/admin/posts/create">
        <div>
          <label for="title">Título</label><br />
          <input id="title" name="title" type="text" value={title} required />
        </div>

        <div>
          <label for="slug">Slug</label><br />
          <input id="slug" name="slug" type="text" value={slug || suggestedSlug} required />
        </div>

        <div>
          <label for="excerpt">Extracto</label><br />
          <textarea id="excerpt" name="excerpt" rows="3">{excerpt}</textarea>
        </div>

        <div>
          <label for="content_md">Contenido</label><br />
          <textarea id="content_md" name="content_md" rows="10" required>{content_md}</textarea>
        </div>

        <div>
          <label for="post_type">Tipo</label><br />
          <select id="post_type" name="post_type">
            <option value="blog" selected={post_type === 'blog'}>blog</option>
            <option value="news" selected={post_type === 'news'}>news</option>
            <option value="tip" selected={post_type === 'tip'}>tip</option>
          </select>
        </div>

        <div>
          <label for="status">Estado</label><br />
          <select id="status" name="status">
            <option value="draft" selected={status === 'draft'}>draft</option>
            <option value="published" selected={status === 'published'}>published</option>
            <option value="archived" selected={status === 'archived'}>archived</option>
          </select>
        </div>

        <br />
        <button type="submit">Guardar publicación</button>
      </form>
    </main>
  </body>
</html>