---
export const prerender = false

import { createSupabaseClient } from '../../../lib/supabase'
import '../../../styles/global.css'

const supabase = createSupabaseClient()

const accessToken = Astro.cookies.get('sb-access-token')
const refreshToken = Astro.cookies.get('sb-refresh-token')

if (!accessToken || !refreshToken) {
  return Astro.redirect('/admin/login')
}

let sessionResult

try {
  sessionResult = await supabase.auth.setSession({
    access_token: accessToken.value,
    refresh_token: refreshToken.value,
  })

  if (sessionResult.error || !sessionResult.data.user) {
    Astro.cookies.delete('sb-access-token', { path: '/' })
    Astro.cookies.delete('sb-refresh-token', { path: '/' })
    return Astro.redirect('/admin/login')
  }
} catch {
  Astro.cookies.delete('sb-access-token', { path: '/' })
  Astro.cookies.delete('sb-refresh-token', { path: '/' })
  return Astro.redirect('/admin/login')
}

const user = sessionResult.data.user

const { data: adminUser } = await supabase
  .from('admin_users')
  .select('id, role, is_active')
  .eq('id', user.id)
  .maybeSingle()

if (!adminUser || adminUser.role !== 'admin' || adminUser.is_active !== true) {
  Astro.cookies.delete('sb-access-token', { path: '/' })
  Astro.cookies.delete('sb-refresh-token', { path: '/' })
  return Astro.redirect('/admin/login?error=Not%20authorized')
}

const { data: posts, error } = await supabase
  .from('posts')
  .select('id, title, slug, status, post_type, created_at, published_at')
  .order('created_at', { ascending: false })
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Posts</title>
  </head>
  <body>
    <main>
      <div class="dashboard">
        <section class="hero">
          <div class="hero__header">
            <div class="hero__text">
              <p class="eyebrow">Publicaciones</p>
              <h1>Administra tu contenido</h1>
              <p>Revisa el estado de los posts, edita entradas existentes y crea nuevas publicaciones desde tu panel.</p>
            </div>
            <div class="actions actions--row">
              <a class="secondary-button" href="/admin">Volver al panel</a>
              <a class="secondary-button" href="/admin/posts/new">Nueva publicación</a>
            </div>
          </div>
        </section>

        <section class="content-card">

          {error && (
            <div class="notification notification--error">
              <strong>Error:</strong>
              <pre>{error.message}</pre>
            </div>
          )}

          {!error && (!posts || posts.length === 0) && (
            <div class="notification notification--info">No hay publicaciones registradas.</div>
          )}

          {!error && posts && posts.length > 0 && (
            <div class="table-wrapper">
              <table class="posts-table">
                <thead>
                  <tr>
                    <th>Título</th>
                    <th>Estado</th>
                    <th>Tipo</th>
                    <th>Slug</th>
                    <th>Creado</th>
                    <th>Publicado</th>
                    <th>Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  {posts.map((post) => (
                    <tr>
                      <td>{post.title}</td>
                      <td>{post.status}</td>
                      <td>{post.post_type}</td>
                      <td>{post.slug}</td>
                      <td>{new Date(post.created_at).toLocaleString()}</td>
                      <td>{post.published_at ? new Date(post.published_at).toLocaleString() : '-'}</td>
                      <td>
                        <a class="table-link" href={`/admin/posts/${post.id}/edit`}>Editar</a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>
      </div>
    </main>
  </body>
</html>