---
export const prerender = false;

import { createSupabaseClient } from "../../../../lib/supabase";
import { ensureUniqueSlugBase } from "../../../../lib/utils/slug";
import "../../../../styles/global.css";

const supabase = createSupabaseClient();

const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
    return Astro.redirect("/admin/login");
}

let sessionResult;

try {
    sessionResult = await supabase.auth.setSession({
        access_token: accessToken.value,
        refresh_token: refreshToken.value,
    });

    if (sessionResult.error || !sessionResult.data.user) {
        Astro.cookies.delete("sb-access-token", { path: "/" });
        Astro.cookies.delete("sb-refresh-token", { path: "/" });
        return Astro.redirect("/admin/login");
    }
} catch {
    Astro.cookies.delete("sb-access-token", { path: "/" });
    Astro.cookies.delete("sb-refresh-token", { path: "/" });
    return Astro.redirect("/admin/login");
}

const user = sessionResult.data.user;

const { data: adminUser } = await supabase
    .from("admin_users")
    .select("id, role, is_active")
    .eq("id", user.id)
    .maybeSingle();

if (!adminUser || adminUser.role !== "admin" || adminUser.is_active !== true) {
    Astro.cookies.delete("sb-access-token", { path: "/" });
    Astro.cookies.delete("sb-refresh-token", { path: "/" });
    return Astro.redirect("/admin/login?error=Not%20authorized");
}

const postId = Astro.params.id;

if (!postId) {
    return Astro.redirect("/admin/posts");
}

const { data: post, error: postError } = await supabase
    .from("posts")
    .select(
        "id, title, slug, excerpt, content_html, post_type, status, published_at",
    )
    .eq("id", postId)
    .maybeSingle();

if (postError || !post) {
    return Astro.redirect("/admin/posts");
}

const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");

const title = Astro.url.searchParams.get("title") ?? post.title;
const slug = Astro.url.searchParams.get("slug") ?? post.slug;
const excerpt = Astro.url.searchParams.get("excerpt") ?? post.excerpt ?? "";
const content_html =
    Astro.url.searchParams.get("content_html") ?? post.content_html;
const post_type = Astro.url.searchParams.get("post_type") ?? post.post_type;
const status = Astro.url.searchParams.get("status") ?? post.status;

const suggestedSlug = title ? ensureUniqueSlugBase(title) : post.slug;
const tinyApiKey = import.meta.env.PUBLIC_TINYMCE_API_KEY ?? "no-api-key";
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Editar publicación</title>
        <script
            src={`https://cdn.tiny.cloud/1/${tinyApiKey}/tinymce/8/tinymce.min.js`}
            referrerpolicy="origin"></script>
    </head>
    <body>
        <main>
            <div class="dashboard">
                <section class="hero">
                    <div class="hero__header">
                        <div class="hero__text">
                            <p class="eyebrow">Editar publicación</p>
                            <h1>Modifica tu contenido</h1>
                            <p>Actualiza el artículo, cambia la imagen destacada o ajusta el estado de publicación.</p>
                        </div>
                        <div class="actions actions--row">
                            <a class="secondary-button" href="/admin">Volver al panel</a>
                            <a class="secondary-button" href="/admin/posts">Ver publicaciones</a>
                        </div>
                    </div>
                </section>

                <section class="content-card">
                    {
                        error && (
                            <div class="notification notification--error">
                                <strong>Error:</strong> {error}
                            </div>
                        )
                    }
                    {
                        success && (
                            <div class="notification notification--success">
                                <strong>{success}</strong>
                            </div>
                        )
                    }

<form method="POST" action="/api/admin/posts/update" id="post-form" class="post-form">
                        <input type="hidden" name="id" value={post.id} />

                        <div class="form-grid">
                            <div class="form-group">
                                <label for="title">Título</label>
                                <input
                                    id="title"
                                    name="title"
                                    type="text"
                                    value={title}
                                    required
                                    class="form-input"
                                />
                            </div>

                            <div class="form-group">
                                <label for="slug">Slug</label>
                                <input
                                    id="slug"
                                    name="slug"
                                    type="text"
                                    value={slug || suggestedSlug}
                                    required
                                    class="form-input"
                                />
                            </div>

                            <div class="form-group form-group--full">
                                <label for="excerpt">Extracto</label>
                                <textarea id="excerpt" name="excerpt" rows="3" class="form-textarea">{excerpt}</textarea>
                            </div>

                            <div class="form-group form-group--full">
                                <label for="content_html">Contenido</label>
                                <textarea id="content_html" name="content_html" class="form-textarea form-textarea--editor">{content_html}</textarea>
                            </div>

                            <div class="form-group">
                                <label for="post_type">Tipo</label>
                                <select id="post_type" name="post_type" class="form-select">
                                    <option value="blog" selected={post_type === "blog"}>blog</option>
                                    <option value="news" selected={post_type === "news"}>news</option>
                                    <option value="tip" selected={post_type === "tip"}>tip</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="status">Estado</label>
                                <select id="status" name="status" class="form-select">
                                    <option value="draft" selected={status === "draft"}>draft</option>
                                    <option value="published" selected={status === "published"}>published</option>
                                    <option value="archived" selected={status === "archived"}>archived</option>
                                </select>
                            </div>

                            <div class="form-group form-group--full">
                                <label for="cover_image">Banner / imagen destacada</label>
                                <input
                                    id="cover_image"
                                    name="cover_image"
                                    type="file"
                                    accept="image/*"
                                    class="form-file"
                                />
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="mt-2 secondary-button">Actualizar publicación</button>
                        </div>
            </form>

            <script>
                window.addEventListener("DOMContentLoaded", () => {
                    if (!window.tinymce) return;

                    window.tinymce.init({
                        selector: "#content_html",
                        menubar: false,
                        plugins: "link lists code table fontsize",
                        toolbar:
                            "undo redo | blocks fontsize | bold italic underline | bullist numlist | link table | code",
                        height: 420,
                        fontsize_formats: "8pt 10pt 12pt 14pt 16pt 18pt 20pt 24pt 28pt 32pt 36pt 48pt 72pt"
                    });

                    const form = document.getElementById("post-form");
                    form?.addEventListener("submit", () => {
                        window.tinymce?.triggerSave();
                    });
                });
            </script>
            </section>
        </div>
    </main>
    </body>
</html>
