---
export const prerender = false

import '../../styles/global.css'

const error = Astro.url.searchParams.get('error')
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ingreso al Panel Admin | SpaceGeek</title>
    <link rel="icon" type="image/x-icon" href="/Logo.png" />
  </head>
  <body>
    <main class="login-page">
      <div class="login-container">
        <div class="login-card">
          <div class="login-header">
            <h1>Iniciar sesión</h1>
            <p>Accede para gestionar tu contenido</p>
          </div>

          {error && (
            <div class="notification notification--error">
              <strong>Error de acceso:</strong> {error}
            </div>
          )}

          <form method="POST" action="/api/auth/login" class="login-form">
            <div class="form-group">
              <label for="email">Correo electrónico</label>
              <input
                id="email"
                name="email"
                type="email"
                placeholder="tu@email.com"
                required
                class="form-input"
                autocomplete="email"
              />
            </div>

            <div class="form-group">
              <label for="password">Contraseña</label>
              <div class="input-password-wrapper">
                <input
                  id="password"
                  name="password"
                  type="password"
                  placeholder="••••••••"
                  required
                  class="form-input"
                  autocomplete="current-password"
                />
                <button type="button" class="toggle-password" id="toggle-password" aria-label="Mostrar contraseña">
                  <svg id="eye-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                  <svg id="eye-off-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                  </svg>
                </button>
              </div>
            </div>

            <button type="submit" class="secondary-button login-button">
              Ingresar al panel
            </button>
          </form>

          <div class="login-footer">
            <p><a href="/">Volver al inicio</a></p>
          </div>
        </div>

        <div class="login-decoration">
          <div class="decoration-circle decoration-circle--1"></div>
          <div class="decoration-circle decoration-circle--2"></div>
          <div class="decoration-circle decoration-circle--3"></div>
        </div>
      </div>
    </main>

    <style>
      .input-password-wrapper {
        position: relative;
        display: flex;
        align-items: center;
      }
      .input-password-wrapper .form-input {
        width: 100%;
        padding-right: 3rem;
      }
      .toggle-password {
        position: absolute;
        right: 1rem;
        background: none;
        border: none;
        cursor: pointer;
        color: #64748b;
        padding: 0;
        display: flex;
        align-items: center;
        transition: color 0.2s ease;
      }
      .toggle-password:hover {
        color: #0f172a;
      }
    </style>

    <script>
      const toggle = document.getElementById('toggle-password');
      const input = document.getElementById('password') as HTMLInputElement | null;
      const eyeOn = document.getElementById('eye-icon') as HTMLElement | null;
      const eyeOff = document.getElementById('eye-off-icon') as HTMLElement | null;

      toggle?.addEventListener('click', () => {
        if (!input || !eyeOn || !eyeOff) return;
        const visible = input.type === 'text';
        input.type = visible ? 'password' : 'text';
        eyeOn.style.display = visible ? 'block' : 'none';
        eyeOff.style.display = visible ? 'none' : 'block';
        toggle.setAttribute('aria-label', visible ? 'Mostrar contraseña' : 'Ocultar contraseña');
      });
    </script>
  </body>
</html>
