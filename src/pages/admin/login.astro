---
export const prerender = false

import '../../styles/global.css'

const accessToken = Astro.cookies.get('sb-access-token')
const refreshToken = Astro.cookies.get('sb-refresh-token')

if (accessToken && refreshToken) {
  return Astro.redirect('/admin')
}

const error = Astro.url.searchParams.get('error')
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ingreso al Panel Admin | SpaceGeek</title>
  </head>
  <body>
    <main class="login-page">
      <div class="login-container">
        <div class="login-card">
          <div class="login-header">
            <h1>Iniciar sesión</h1>
            <p>Accede para gestionar tu contenido</p>
          </div>

          {error && (
            <div class="notification notification--error">
              <strong>Error de acceso:</strong> {error}
            </div>
          )}

          <form method="POST" action="/api/auth/login" class="login-form">
            <div class="form-group">
              <label for="email">Correo electrónico</label>
              <input
                id="email"
                name="email"
                type="email"
                placeholder="tu@email.com"
                required
                class="form-input"
                autocomplete="email"
              />
            </div>

            <div class="form-group">
              <label for="password">Contraseña</label>
              <input
                id="password"
                name="password"
                type="password"
                placeholder="••••••••"
                required
                class="form-input"
                autocomplete="current-password"
              />
            </div>

            <button type="submit" class="secondary-button login-button">
              Ingresar al panel
            </button>
          </form>

          <div class="login-footer">
            <p><a href="/">Volver al inicio</a></p>
          </div>
        </div>

        <div class="login-decoration">
          <div class="decoration-circle decoration-circle--1"></div>
          <div class="decoration-circle decoration-circle--2"></div>
          <div class="decoration-circle decoration-circle--3"></div>
        </div>
      </div>
    </main>
  </body>
</html>