---
import PublicLayout from '../../layouts/PublicLayout.astro';
import { createSupabaseClient } from '../../lib/supabase'
import '../../styles/global.css'

const supabase = createSupabaseClient()

const { data: posts, error } = await supabase
  .from('posts')
  .select('id, title, slug, excerpt, cover_image_path, post_type, published_at')
  .eq('status', 'published')
  .order('published_at', { ascending: false })
---

<PublicLayout title="Publicaciones | SpaceGeek">
  <main class="dashboard posts-page">
    <section class="hero hero--posts">
      <div class="hero__text">
        <p class="eyebrow">Blog</p>
        <h1>Publicaciones</h1>
        <p>Lee las últimas noticias y artículos de SpaceGeek en un formato cómodo y visual.</p>
      </div>
      <div class="actions actions--row">
        <a class="secondary-button" href="/">Inicio</a>
        <a class="secondary-button" href="/admin/login">Panel Admin</a>
      </div>
    </section>

    {error && (
      <div class="notification notification--error">
        <strong>Error:</strong> {error.message}
      </div>
    )}

    {!error && (!posts || posts.length === 0) && (
      <div class="note">No hay publicaciones publicadas todavía.</div>
    )}

    {!error && posts && posts.length > 0 && (
      <section class="post-grid">
        {posts.map((post) => (
          <article class="post-card">
            {post.cover_image_path && (
              <img
                class="post-card__image"
                src={supabase.storage.from('post-images').getPublicUrl(post.cover_image_path).data.publicUrl}
                alt={post.title}
              />
            )}
            <div class="post-card__content">
              <div class="post-card__meta">
                <span class="tag-pill">{post.post_type}</span>
                {post.published_at && (
                  <span>{new Date(post.published_at).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                )}
              </div>
              <h2 class="post-card__title">
                <a href={`/posts/${post.slug}`}>{post.title}</a>
              </h2>
              {post.excerpt && <p class="post-card__excerpt">{post.excerpt}</p>}
              <a class="table-link" href={`/posts/${post.slug}`}>Leer publicación</a>
            </div>
          </article>
        ))}
      </section>
    )}
  </main>
</PublicLayout>