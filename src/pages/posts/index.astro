---
export const prerender = false

import PublicLayout from "../../layouts/PublicLayout.astro";
import { createSupabaseClient } from "../../lib/supabase";
import { supabaseAdmin } from "../../lib/supabase/server";
import "../../styles/global.css";

const supabase = createSupabaseClient();

const activeType = Astro.url.searchParams.get("type") ?? "";

let query = supabaseAdmin
  .from("posts")
  .select("id, title, slug, excerpt, cover_image_path, post_type, published_at, author:admin_users!author_id(display_name, email)")
  .eq("status", "published")
  .order("published_at", { ascending: false });

if (activeType) {
  query = query.eq("post_type", activeType);
}

const { data: posts, error } = await query;

// Fetch sections that have at least one published post (for filter pills)
const { data: allPublished } = await supabaseAdmin
  .from("posts")
  .select("post_type")
  .eq("status", "published");

const usedTypes = new Set((allPublished ?? []).map((p) => p.post_type));

const { data: sections } = await supabaseAdmin
  .from("post_sections")
  .select("slug, label")
  .order("sort_order", { ascending: true });

const filterSections = (sections ?? []).filter((s) => usedTypes.has(s.slug));
---

<PublicLayout title="Publicaciones | SpaceGeek">
  <main class="dashboard posts-page">
    <section class="hero hero--posts">
      <div class="hero__text">
        <p class="eyebrow">Blog</p>
        <h1>Publicaciones</h1>
        <p>
          Lee las últimas noticias y artículos de SpaceGeek en un formato cómodo
          y visual.
        </p>
        {filterSections.length > 0 && (
          <div class="filter-select-wrap">
            <select
              id="type-filter"
              class="filter-select"
              onchange="location.href = this.value ? '/posts?type=' + this.value : '/posts'"
            >
              <option value="" selected={!activeType}>Todas las secciones</option>
              {filterSections.map((s) => (
                <option value={s.slug} selected={activeType === s.slug}>{s.label}</option>
              ))}
            </select>
          </div>
        )}
      </div>
      {
        error && (
          <div class="notification notification--error">
            <strong>Error:</strong> {error.message}
          </div>
        )
      }

      {
        !error && (!posts || posts.length === 0) && (
          <div class="note">No hay publicaciones publicadas todavía.</div>
        )
      }

      {
        !error && posts && posts.length > 0 && (
          <section class="post-grid">
            {posts.map((post) => (
              <article class="post-card">
                {post.cover_image_path && (
                  <img
                    class="post-card__image"
                    src={
                      supabase.storage
                        .from("post-images")
                        .getPublicUrl(post.cover_image_path).data.publicUrl
                    }
                    alt={post.title}
                  />
                )}
                <div class="post-card__content">
                  <div class="post-card__meta">
                    <span class="tag-pill">{post.post_type}</span>
                    {post.published_at && (
                      <span>
                        {new Date(post.published_at).toLocaleDateString(
                          "es-ES",
                          { year: "numeric", month: "short", day: "numeric" },
                        )}{" "}
                        por {(post.author as any)?.display_name || (post.author as any)?.email?.split('@')[0] || 'SpaceGeek'}{" "}
                      </span>
                    )}
                  </div>
                  <h2 class="post-card__title">
                    <a href={`/posts/${post.slug}`}>{post.title}</a>
                  </h2>
                  {post.excerpt && (
                    <p class="post-card__excerpt">{post.excerpt}</p>
                  )}
                  <a class="table-link" href={`/posts/${post.slug}`}>
                    Leer publicación
                  </a>
                </div>
              </article>
            ))}
          </section>
        )
      }
    </section>
  </main>
</PublicLayout>

