---
import PublicLayout from '../layouts/PublicLayout.astro';
import '../styles/global.css';
---

<PublicLayout title="Acerca de | SpaceGeek">
  <main class="dashboard about-page">
    <section class="hero hero--about">
      <div class="hero__text">
        <p class="eyebrow">Sobre nosotros</p>
        <h1>Acerca de SpaceGeek</h1>
        <p>Conoce más sobre nuestro proyecto y visión.</p>
      </div>
    </section>

    <section class="content-section">
      <div class="content-card">
        <h2>Nuestra misión</h2>
        <p>
          SpaceGeek es un blog dedicado a la cultura geek, tecnología y entretenimiento.
          Nuestro objetivo es mantenerte informado sobre las últimas tendencias, noticias
          y análisis en el mundo geek.
        </p>

        <h2>¿Qué encontrarás aquí?</h2>
        <ul>
          <li>Noticias sobre anime y manga</li>
          <li>Análisis de videojuegos</li>
          <li>Reseñas de tecnología</li>
          <li>Artículos sobre cultura pop</li>
          <li>Tutoriales y guías</li>
        </ul>

        <h2>Contáctanos</h2>
        <p>
          ¿Tienes alguna sugerencia o quieres colaborar? ¡Nos encantaría escucharte!
          Puedes encontrarnos en nuestras redes sociales.
        </p>

        <div class="social-links">
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="social-link" title="Twitter">
            𝕏
          </a>
          <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" class="social-link" title="YouTube">
            ▶
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="social-link" title="Instagram">
            📷
          </a>
          <a href="https://discord.com" target="_blank" rel="noopener noreferrer" class="social-link" title="Discord">
            💬
          </a>
        </div>
      </div>
    </section>
  </main>
</PublicLayout>