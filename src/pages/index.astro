---
import PublicLayout from "../layouts/PublicLayout.astro";
import { createSupabaseClient } from "../lib/supabase";
import { supabaseAdmin } from "../lib/supabase/server";
import type { SocialMediaItem } from "../types/social";
import "../styles/global.css";

const supabase = createSupabaseClient();

const { data: recentPosts, error } = await supabase
  .from("posts")
  .select("id, title, slug, excerpt, cover_image_path, post_type, published_at")
  .eq("status", "published")
  .order("published_at", { ascending: false })
  .limit(6);

let socialItems: SocialMediaItem[] = [];
let socialError: string | null = null;

const { data: socialData, error: socialDbError } = await supabaseAdmin
  .from('social_media_posts')
  .select('id, platform, external_id, title, description, url, image_url, inserted_at, source, active, sync_status, priority')
  .eq('active', true)
  .order('priority', { ascending: false })
  .order('inserted_at', { ascending: false });

if (socialDbError) {
  socialError = socialDbError.message;
} else {
  socialItems = (socialData ?? []).map(item => ({
    id: item.id,
    platform: item.platform,
    external_id: item.external_id,
    title: item.title?.trim() || 'Ver contenido',
    description: item.description?.trim() || '',
    url: item.url,
    image_url: item.image_url?.trim() || null,
    inserted_at: item.inserted_at,
    published_at: item.inserted_at,
    source: item.source,
    active: item.active,
    sync_status: item.sync_status,
    priority: item.priority,
  }));
}

type Platform = 'youtube' | 'instagram' | 'x';
const platformLabels: Record<Platform, string> = { youtube: 'YouTube', instagram: 'Instagram', x: 'X' };
const platformOrder: Platform[] = ['x', 'youtube', 'instagram'];

const socialByPlatform = platformOrder.reduce<Record<Platform, SocialMediaItem[]>>(
  (acc, p) => ({ ...acc, [p]: socialItems.filter(i => i.platform === p) }),
  { youtube: [], instagram: [], x: [] }
);

function getAccountName(item: SocialMediaItem): string {
  if (item.platform === 'x') {
    const m = item.url.match(/(?:x\.com|twitter\.com)\/([^/]+)\/status/);
    return m ? `@${m[1]}` : '@';
  }
  if (item.platform === 'youtube') return 'YouTube';
  return 'Instagram';
}

const allSocialItems = platformOrder.flatMap(p => socialByPlatform[p]);
---

<PublicLayout title="SpaceGeek | Blog">
  <div class="dashboard home-page">
    <section class="hero__imgs">
        <div class="img-primary">
          <img
            src="https://kwqlnrndicwgucwerojk.supabase.co/storage/v1/object/public/Fotos%20prueba/img1.png"
            alt=""
          />
        </div>
        <div class="img-secondary">
          <div class="imgSection">
            <div class="img-superior-banner">
              <img
                src="https://kwqlnrndicwgucwerojk.supabase.co/storage/v1/object/public/Fotos%20prueba/img3.png"
                alt=""
              />
            </div>
            <div class="img-inferior-banner">
              <img
                src="https://kwqlnrndicwgucwerojk.supabase.co/storage/v1/object/public/Fotos%20prueba/img4.png"
                alt=""
              />
            </div>
          </div>
          <div class="imgSection imgSection--right">
            <div class="img-superior-banner bordeSuperiorRedondo">
              <img
                src="https://kwqlnrndicwgucwerojk.supabase.co/storage/v1/object/public/Fotos%20prueba/img2.png"
                alt=""
              />
            </div>
            <div class="img-inferior-banner">
              <img
                src="https://kwqlnrndicwgucwerojk.supabase.co/storage/v1/object/public/Fotos%20prueba/img5.png"
                alt=""
              />
            </div>
          </div>
        </div>
      <!-- <div class="hero__summary">
        <div class="summary-card">
          <span>Últimas publicaciones</span>
          <strong>{recentPosts?.length ?? 0}</strong>
        </div>
      </div> -->
    </section>

    <section class="home-grid">
      <div class="home-main">
        {
          !error && (!recentPosts || recentPosts.length === 0) && (
            <div class="note">No hay publicaciones publicadas todavía.</div>
          )
        }

        {
          error && (
            <div class="notification notification--error">
              <strong>Error:</strong> {error.message}
            </div>
          )
        }

        {
          !error && recentPosts && recentPosts.length > 0 && (
            <div class="post-list">
              {recentPosts.map((post) => (
                <a class="post-card" href={`/posts/${post.slug}`}>
                  {post.cover_image_path && (
                    <img
                      class="post-card__image"
                      src={
                        supabase.storage
                          .from("post-images")
                          .getPublicUrl(post.cover_image_path).data.publicUrl
                      }
                      alt={post.title}
                    />
                  )}
                  <div class="post-card__content">
                    <div class="post-card__meta">
                      <span class="tag-pill">{post.post_type}</span>
                    </div>
                    <h3 class="post-card__title">{post.title}</h3>
                    {post.excerpt && (
                      <p class="post-card__excerpt">{post.excerpt}</p>
                    )}
                     <span class="spanInfo">
                        {new Date(post.published_at).toLocaleDateString(
                          "es-ES",
                          { year: "numeric", month: "long", day: "numeric" },
                        )}
                        por OscarSpaceNG 
                      </span>
                  </div>
                </a>
              ))}
            </div>
          )
        }
      </div>
      <aside class="home-sidebar">
        <div class="sidebar-card sidebar-card--social">
          {socialError && (
            <div class="notification notification--error">
              <strong>Error:</strong> {socialError}
            </div>
          )}
          {!socialError && socialItems.length === 0 && (
            <p class="note">No hay contenido social disponible.</p>
          )}

          {/* ── X ── */}
          {socialByPlatform.x.length > 0 && (
            <div class="social-section" id="sc-x-section">
              <div class="topRedes">
              <p class="colorWhite">OSCARSPACENG</p>
              <p class="social-section__label">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="#fff" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.262 5.636 5.902-5.636zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </p>
              </div>
              <div class="x-snap" id="x-snap">
                {socialByPlatform.x.map((item: SocialMediaItem) => (
                  <div class="x-snap__item">
                    <div class="x-snap__embed">
                      <blockquote class="twitter-tweet" data-dnt="true" data-conversation="none" data-theme="dark">
                        <a href={item.url}></a>
                      </blockquote>
                    </div>
                  </div>
                ))}
              </div>

              {socialByPlatform.x.length > 1 && (
                <div class="sc__nav">
                  <button class="sc__btn" id="x-prev" aria-label="Anterior">&#8249;</button>
                  <div class="sc__dots">
                    {socialByPlatform.x.map((_: SocialMediaItem, i: number) => (
                      <button class={`sc__dot${i === 0 ? ' is-active' : ''}`} data-idx={i} aria-label={`Tweet ${i + 1}`}></button>
                    ))}
                  </div>
                  <button class="sc__btn" id="x-next" aria-label="Siguiente">&#8250;</button>
                </div>
              )}

              <script is:inline>
                (function () {
                  var snap = document.getElementById('x-snap');
                  if (!snap) return;
                  var items = snap.querySelectorAll('.x-snap__item');
                  var dots  = document.querySelectorAll('#sc-x-section .sc__dot');
                  var prev  = document.getElementById('x-prev');
                  var next  = document.getElementById('x-next');
                  if (items.length < 2) return;

                  var cur = 0;

                  function scrollTo(idx) {
                    cur = (idx + items.length) % items.length;
                    snap.scrollTo({ left: snap.offsetWidth * cur, behavior: 'smooth' });
                    dots.forEach(function (d, i) {
                      d.classList.toggle('is-active', i === cur);
                    });
                  }

                  prev && prev.addEventListener('click', function () { scrollTo(cur - 1); });
                  next && next.addEventListener('click', function () { scrollTo(cur + 1); });
                  dots.forEach(function (dot) {
                    dot.addEventListener('click', function () { scrollTo(parseInt(dot.dataset.idx)); });
                  });

                  // Sincronizar punto activo al hacer scroll manual / swipe
                  snap.addEventListener('scrollend', function () {
                    cur = Math.round(snap.scrollLeft / snap.offsetWidth);
                    dots.forEach(function (d, i) { d.classList.toggle('is-active', i === cur); });
                  });
                })();
              </script>
            </div>
          )}

          {/* ── YouTube ── */}
          {socialByPlatform.youtube.length > 0 && (
            <div class="social-section">
               <div class="topRedes">
              <p class="colorWhite">OSCARSPACENG</p>
              <p class="social-section__label">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="30" height="20" aria-hidden="true">
                  <path fill="#ffff" d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </p>
              </div>
              
              <div class="sc" id="sc-yt">
                <div class="sc__track" id="sc-yt-track">
                  {socialByPlatform.youtube.map((item: SocialMediaItem, i: number) => (
                    <div class="sc__slide">
                      <a class="sc-card sc-card--yt" href={item.url} target="_blank" rel="noopener noreferrer">
                        {item.image_url
                          ? <img src={item.image_url} alt={item.title || 'Video'} loading="lazy" />
                          : <div class="sc-card__yt-placeholder">▶</div>
                        }
                        {item.title && item.title !== 'Ver contenido' && (
                          <p class="sc-card__title">{item.title}</p>
                        )}
                      </a>
                    </div>
                  ))}
                </div>
                {socialByPlatform.youtube.length > 1 && (
                  <div class="sc__nav">
                    <button class="sc__btn" id="sc-yt-prev" aria-label="Anterior">&#8249;</button>
                    <div class="sc__dots">
                      {socialByPlatform.youtube.map((_: SocialMediaItem, i: number) => (
                        <button class={`sc__dot${i === 0 ? ' is-active' : ''}`} data-idx={i} aria-label={`Video ${i + 1}`}></button>
                      ))}
                    </div>
                    <button class="sc__btn" id="sc-yt-next" aria-label="Siguiente">&#8250;</button>
                  </div>
                )}
              </div>
            </div>
          )}

          {/* ── Instagram ── */}
          {socialByPlatform.instagram.length > 0 && (
            <div class="social-section">
              <div class="topRedes">
              <p class="colorWhite">OSCARSPACENG</p>
              <p class="social-section__label">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                  <defs>
                    <linearGradient id="ig-lbl" x1="0%" y1="100%" x2="100%" y2="0%">
                      <stop offset="0%" style="stop-color:#ffff"/>
                      <stop offset="50%" style="stop-color:#ffff"/>
                      <stop offset="100%" style="stop-color:#fff"/>
                    </linearGradient>
                  </defs>
                  <path fill="url(#ig-lbl)" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </p>
              </div>
              {socialByPlatform.instagram.map((item: SocialMediaItem) => (
                <a class="sc-card sc-card--ig" href={item.url} target="_blank" rel="noopener noreferrer">
                  <svg class="sc-card--ig__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
                    <defs>
                      <linearGradient id="ig-card" x1="0%" y1="100%" x2="100%" y2="0%">
                        <stop offset="0%" style="stop-color:#f09433"/>
                        <stop offset="50%" style="stop-color:#dc2743"/>
                        <stop offset="100%" style="stop-color:#bc1888"/>
                      </linearGradient>
                    </defs>
                    <path fill="url(#ig-card)" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                  <div class="sc-card__info">
                    <span class="sc-card__title">
                      {item.title && item.title !== 'Instagram post' ? item.title : 'Ver publicación'}
                    </span>
                    <span class="sc-card__link">Abrir en Instagram →</span>
                  </div>
                </a>
              ))}
            </div>
          )}

          <script is:inline>
            (function () {
              function initCarousel(trackId, prevId, nextId, scId) {
                var track = document.getElementById(trackId);
                var sc = document.getElementById(scId);
                if (!track || !sc) return;
                var slides = track.querySelectorAll('.sc__slide');
                if (slides.length < 2) return;
                var dots = sc.querySelectorAll('.sc__dot');
                var prev = document.getElementById(prevId);
                var next = document.getElementById(nextId);
                var cur = 0, timer;

                function goTo(idx) {
                  if (dots[cur]) dots[cur].classList.remove('is-active');
                  cur = (idx + slides.length) % slides.length;
                  track.style.transform = 'translateX(-' + (cur * 100) + '%)';
                  if (dots[cur]) dots[cur].classList.add('is-active');
                }

                function startAuto() { timer = setInterval(function () { goTo(cur + 1); }, 6000); }
                function resetAuto() { clearInterval(timer); startAuto(); }

                prev && prev.addEventListener('click', function () { goTo(cur - 1); resetAuto(); });
                next && next.addEventListener('click', function () { goTo(cur + 1); resetAuto(); });
                dots.forEach(function (dot) {
                  dot.addEventListener('click', function () { goTo(parseInt(dot.dataset.idx)); resetAuto(); });
                });
                startAuto();
              }

              initCarousel('sc-yt-track', 'sc-yt-prev', 'sc-yt-next', 'sc-yt');
            })();
          </script>
        </div>
      </aside>
    </section>
  </div>

{socialByPlatform.x.length > 0 && (
  <script is:inline async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
)}
</PublicLayout>
