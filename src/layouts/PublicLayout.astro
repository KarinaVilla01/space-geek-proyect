---
export interface Props {
  title: string;
}

const { title } = Astro.props;
import "../styles/public-layout.css";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/Logo.png" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-container">
        <div class="header-logo">
          <a href="/" class="logo-link">
            <h5 class="header-title">Spacenoid</h5>
            <h4 class="header-title redLetter">Geek</h4>
            <img src="/Logo.png" alt="SpaceGeek" class="header-image" />
          </a>
        </div>
        <nav class="header-nav">
          <a href="/" class="nav-link">Inicio</a>
          <a href="/posts" class="nav-link">Publicaciones</a>
          <a href="/about" class="nav-link">Acerca de</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <slot />
    </main>

    <footer class="site-footer">
        <div class="lineRed"></div>
      <div class="footer-container">
        <div class="footer-content">
          <div class="footer-section podcast">
            <img src="./PODCASILLO.png" alt="">
            <p>Noticias, artículos y análisis para fans de la cultura geek.</p>
          </div>
          <div class="footer-section">
            <h4>Enlaces</h4>
            <ul class="footer-links">
              <li><a href="/">Terminos y condiciones</a></li>
              <li><a href="/posts">Publicaciones</a></li>
              <li><a href="/">Contactános</a></li>
              <li><a href="/about">Acerca de</a></li>
            </ul>
          </div>
          <div class="footer-section">
            <h4>Conectar</h4>
            <div class="social-links">
              <a
                href="https://twitter.com"
                target="_blank"
                rel="noopener noreferrer"
                title="X (Twitter)"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill=#0a0a4a width="18" height="18">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835-8.162-10.665h7.065l4.254 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
              <a
                href="https://youtube.com"
                target="_blank"
                rel="noopener noreferrer"
                title="YouTube"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill=#0a0a4a width="18" height="18">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
              <a
                href="https://instagram.com"
                target="_blank"
                rel="noopener noreferrer"
                title="Instagram"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill=#0a0a4a width="18" height="18">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                </svg>
              </a>
              <a
                href="https://discord.com"
                target="_blank"
                rel="noopener noreferrer"
                title="Discord"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill=#0a0a4a width="18" height="18">
                  <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.042.028.056 1.777 1.304 3.501 2.098 5.198 2.623a.075.075 0 0 0 .083-.028 14.77 14.77 0 0 0 1.272-2.069.07.07 0 0 0-.038-.098 13.28 13.28 0 0 1-1.889-.9.074.074 0 0 1-.007-.123c.127-.095.254-.195.376-.296a.07.07 0 0 1 .074-.01c3.963 1.813 8.25 1.813 12.164 0a.07.07 0 0 1 .075.009c.122.102.249.202.377.297a.074.074 0 0 1-.006.124 12.38 12.38 0 0 1-1.89.9.07.07 0 0 0-.038.099c.382.697.808 1.399 1.27 2.068a.074.074 0 0 0 .084.028c1.706-.525 3.43-1.32 5.207-2.623a.075.075 0 0 0 .028-.055c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.028zM8.02 15.33c-1.182 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2026 SpaceGeek. Todos los derechos reservados.</p>
          <p class="footer-credit">Diseñado y desarrollado por <a href="https://www.instagram.com/karin.sak01/" target="_blank" rel="noopener noreferrer">KarinSak</a></p>
        </div>
      </div>
    </footer>
  </body>
</html>
