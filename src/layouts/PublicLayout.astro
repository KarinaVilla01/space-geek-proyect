---
export const prerender = false;

export interface Props {
  title: string;
}

const { title } = Astro.props;
import "../styles/public-layout.css";
import { supabaseAdmin } from "../lib/supabase/server";

const { data: navSections } = await supabaseAdmin
  .from("post_sections")
  .select("slug, label")
  .order("sort_order", { ascending: true });
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/Logo.png" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-container">
        <div class="header-logo">
          <a href="/" class="logo-link">
            <img src="/SpaceNoidGeek_Logo.png" alt="SpaceGeek" class="header-image" />
          </a>
        </div>
        <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav class="header-nav" id="header-nav">
          <a href="/" class="nav-link">Inicio</a>
          <div class="nav-dropdown" id="pub-dropdown">
            <button class="nav-link nav-dropdown__toggle" aria-expanded="false" aria-haspopup="listbox">
              Publicaciones
              <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true" class="nav-dropdown__chevron">
                <path d="M2 4l4 4 4-4"/>
              </svg>
            </button>
            <ul class="nav-dropdown__menu" role="listbox">
              <li><a href="/posts" class="nav-dropdown__item">Todas las secciones</a></li>
              {(navSections ?? []).map((s) => (
                <li><a href={`/posts?type=${s.slug}`} class="nav-dropdown__item">{s.label}</a></li>
              ))}
            </ul>
          </div>
          <a href="/about" class="nav-link">Acerca de</a>
        </nav>
      </div>
    </header>

    <script>
      const hamburger = document.getElementById('hamburger');
      const nav = document.getElementById('header-nav');
      const dropdown = document.getElementById('pub-dropdown');
      const toggle = dropdown?.querySelector('.nav-dropdown__toggle') as HTMLButtonElement | null;

      function closeDropdown() {
        toggle?.setAttribute('aria-expanded', 'false');
        dropdown?.classList.remove('nav-dropdown--open');
      }

      function closeMobileNav() {
        nav?.classList.remove('header-nav--open');
        hamburger?.classList.remove('hamburger--open');
        hamburger?.setAttribute('aria-expanded', 'false');
      }

      hamburger?.addEventListener('click', () => {
        const open = nav?.classList.toggle('header-nav--open');
        hamburger.setAttribute('aria-expanded', String(open));
        hamburger.classList.toggle('hamburger--open', open);
        if (!open) closeDropdown();
      });

      toggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        dropdown?.classList.toggle('nav-dropdown--open', !expanded);
      });

      document.addEventListener('click', (e) => {
        if (!dropdown?.contains(e.target as Node)) closeDropdown();
      });

      dropdown?.querySelectorAll('.nav-dropdown__item').forEach((item) => {
        item.addEventListener('click', () => {
          closeDropdown();
          closeMobileNav();
        });
      });

      nav?.querySelectorAll('.nav-link:not(.nav-dropdown__toggle)').forEach((link) => {
        link.addEventListener('click', () => closeMobileNav());
      });
    </script>

    <main class="main-content">
      <slot />
    </main>

    <footer class="site-footer">
        <div class="lineRed">
          <img src="/Your_Space.png" alt="Your Space" class="lineRedImage">
        </div>
      <div class="footer-container">
        <div class="footer-content">
          <div class="footer-section karinSpace">
            <img src="/Karin.png" alt="Karina Villa">
            <p>Diseñado y desarrollado por Karina Villa Developer</p>
            <p class="footer-credit">Cualquier información de contacto click aquí -> <a href="https://www.instagram.com/karin.sak01/" target="_blank" rel="noopener noreferrer">Karina Villa</a></p>
          </div>
          <div class="footer-section">
            <h4>Enlaces</h4>
            <ul class="footer-links">
              <li><a href="/">Terminos y condiciones</a></li>
              <li><a href="/posts">Publicaciones</a></li>
