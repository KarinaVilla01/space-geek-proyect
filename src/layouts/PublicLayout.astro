---
export interface Props {
  title: string;
}

const { title } = Astro.props;
import "../styles/public-layout.css";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-container">
        <div class="header-logo">
          <a href="/" class="logo-link">
            <h5 class="header-title">Spacenoid</h5>
            <h4 class="header-title redLetter">Geek</h4>
            <img src="/Cover.png" alt="SpaceGeek" class="header-image" />
          </a>
        </div>
        <nav class="header-nav">
          <a href="/" class="nav-link">Inicio</a>
          <a href="/posts" class="nav-link">Publicaciones</a>
          <a href="/about" class="nav-link">Acerca de</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-content">
          <div class="footer-section">
            <h3>SpaceGeek</h3>
            <p>Noticias, artículos y análisis para fans de la cultura geek.</p>
          </div>
          <div class="footer-section">
            <h4>Enlaces</h4>
            <ul class="footer-links">
              <li><a href="/">Inicio</a></li>
              <li><a href="/posts">Publicaciones</a></li>
              <li><a href="/about">Acerca de</a></li>
            </ul>
          </div>
          <div class="footer-section">
            <h4>Conectar</h4>
            <div class="social-links">
              <a
                href="https://twitter.com"
                target="_blank"
                rel="noopener noreferrer"
                title="Twitter">𝕏</a
              >
              <a
                href="https://youtube.com"
                target="_blank"
                rel="noopener noreferrer"
                title="YouTube">▶</a
              >
              <a
                href="https://instagram.com"
                target="_blank"
                rel="noopener noreferrer"
                title="Instagram">📷</a
              >
              <a
                href="https://discord.com"
                target="_blank"
                rel="noopener noreferrer"
                title="Discord">💬</a
              >
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2024 SpaceGeek. Todos los derechos reservados.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
